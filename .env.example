# OpenTrading local secrets — copy to `.env` (git-ignored) and fill in.
#   cp .env.example .env   &&   edit .env
# Used by `ot email` + the daily / news / multi-user emails (tools/email/send_email.py).
# The password is read ONLY from this file / the environment, never the command line.
# Use an APP PASSWORD or API KEY — never your normal account password.

# --- Pick ONE provider preset (sets host/port/security automatically) ----------
# resend | gmail | outlook | office365 | icloud | yahoo
#
# Which to use?
#   • gmail   — RECOMMENDED to email *anyone* (incl. external / overseas like qq.com).
#               Turn 2-Step Verification ON, then make an App Password at
#               myaccount.google.com/apppasswords (16 lowercase letters). Reliable.
#   • resend  — easiest to email YOURSELF only. Free tier (onboarding@resend.dev) delivers
#               ONLY to your Resend-account email; external recipients need a VERIFIED DOMAIN
#               at resend.com/domains (then point OT_EMAIL_FROM at that domain).
#   • outlook / office365 — NOTE: Microsoft has DISABLED app-password SMTP for personal
#               Outlook.com accounts (auth 535). Only works for Workspace/365 that still allow it.
OT_SMTP_PROVIDER=gmail

# --- Credentials ---------------------------------------------------------------
# gmail / outlook / icloud / yahoo : user = your full address ; pass = a 16-char APP password.
# resend                           : user = the literal "resend" ; pass = an API key (re_...).
OT_SMTP_USER=you@gmail.com
OT_SMTP_PASS=your-app-password-or-api-key

# --- Addressing ----------------------------------------------------------------
# FROM must be an address you're allowed to send as:
#   gmail/outlook -> your own address ; resend free -> onboarding@resend.dev (or your verified domain).
OT_EMAIL_FROM=you@gmail.com
OT_EMAIL_TO=you@example.com          # default recipient; `--to` overrides per send.
                                     # (multi-user: per-recipient comes from watchlist.<id>.json)

# --- Optional ------------------------------------------------------------------
# OT_EMAIL_LANG=zh                   # write the brief / news email in Simplified Chinese
# OT_FJ_FEED_URL=...                 # personalized FinancialJuice feed (else the public one)
# OT_NEWS_FEEDS=financialjuice,cnbc  # default news sources to aggregate

# --- `ot web` dashboard — optional AI analysis (pick ANY of 3 engines) ---------
# The dashboard's data panels are keyless; the per-ticker AI analysis runs on
# whichever engine(s) you enable below — switch live from the header dropdown.
#
# 1) Gemini — free key: https://aistudio.google.com
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash            # optional (default)
# GEMINI_MODEL_FALLBACK=gemini-2.0-flash   # optional, comma-separated fallbacks
#
# 2) OpenRouter — ONE key, any model (GPT / Claude / Gemini / DeepSeek / GLM /
#    Grok / Qwen…): https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=z-ai/glm-5.2            # optional default slug (cheap + strong)
#
# 3) Claude Code — NO key: uses your Claude subscription via the `claude` CLI
#    (nothing to configure; the engine appears when the CLI is on PATH).
#
# Default engine when several are enabled: gemini | openrouter | claude
# OT_LLM_ENGINE=gemini

# --- Advanced (only if NOT using a provider preset above) ----------------------
# OT_SMTP_HOST=smtp.example.com
# OT_SMTP_PORT=587
# OT_SMTP_SECURITY=starttls          # starttls | ssl | none
